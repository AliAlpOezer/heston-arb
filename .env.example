# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real credentials.

# ── Massive (formerly Polygon.io) — options chain data ──────────────────────
# Optional when using --alpaca: the loop falls back to Alpaca's indicative feed.
# Required when using --ibkr or running CBOE backtests.
POLYGON_API_KEY=your_massive_api_key_here

# ── Alpaca Markets (order execution) ────────────────────────────────────────
# Get keys at https://app.alpaca.markets → Settings → API Keys
# Paper trading keys are separate from live keys.
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ── FRED (risk-free rate, optional) ─────────────────────────────────────────
# Free API key at https://fred.stlouisfed.org/docs/api/api_key.html
# If not set, rates fall back to hardcoded annual tables in data/rates.py.
FRED_API_KEY=your_fred_api_key_here
